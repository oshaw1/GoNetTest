{{define "test_quadrant"}}
<div id="test-quadrant" class="quadrant">
    <div id="date-sidebar" class="sidebar">

        {{/* scrollable list of dates */}}
        <div class="sidebar-dates">
            {{range .Dates}}
                <div class="sidebar-item-group sidebar-button">

                    <button
                        hx-get="/dashboard/tests?date={{.}}"
                        hx-target="#test-results"
                        hx-include="#test-selection select"
                        class="sidebar-main-action"
                    >
                        {{.}}
                    </button>

                    <button
                        class="btn sidebar-delete-btn delete-icon-circle"
                        hx-delete="/networktest/delete?date={{.}}"
                        hx-confirm="Are you sure you want to permanently delete ALL test data for {{.}}? This action cannot be reversed."
                        hx-on::after-request="if(event.detail.successful) { window.location.reload(); }"
                        title="Permanently delete data for {{.}}"
                    >
                        🗑️
                    </button>
                </div>
            {{end}}
        </div>

        {{/* pinned settings footer */}}
        <div class="sidebar-footer">
            <button type="button" class="settings-btn" onclick="showSettingsModal()" title="Settings">
                <span class="gear">⚙</span>
                <span class="label">Settings</span>
            </button>
        </div>
    </div>

    <div class="content-area">
        <div id="test-selection">
            {{template "test_selection" .}}
        </div>
        <div id="test-results">
            {{template "test_results" .}}
        </div>
    </div>
</div>

{{/* ---- Settings modal ---- */}}
<div id="settings-modal" class="modal">
    <div class="modal-content">
        <h3>Settings</h3>

        <div class="settings-section">
            <span class="settings-label">Theme</span>
            <div class="theme-options">
                <button type="button" class="theme-option" data-pref="light">
                    <span class="theme-icon">☀</span>
                    Light
                </button>
                <button type="button" class="theme-option" data-pref="dark">
                    <span class="theme-icon">☾</span>
                    Dark
                </button>
                <button type="button" class="theme-option" data-pref="system">
                    <span class="theme-icon">🖥</span>
                    System
                </button>
            </div>
        </div>

        <div class="settings-section">
            <span class="settings-label">Dashboard</span>
            <div class="form-group">
                <label for="cfg-recentDays">Recent Days</label>
                <input type="number" id="cfg-recentDays" min="1" max="365" placeholder="7">
            </div>
        </div>

        <div class="settings-section">
            <span class="settings-label">Test Configuration</span>

            <details class="settings-collapsible">
                <summary class="settings-collapsible-header">
                    ICMP
                    <svg class="chev" width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="settings-collapsible-body">
                    <div class="form-group">
                        <label for="cfg-icmp-packetCount">Packet Count</label>
                        <input type="number" id="cfg-icmp-packetCount" min="1" placeholder="20">
                    </div>
                    <div class="form-group">
                        <label for="cfg-icmp-timeoutSeconds">Timeout (s)</label>
                        <input type="number" id="cfg-icmp-timeoutSeconds" min="1" placeholder="2">
                    </div>
                </div>
            </details>

            <details class="settings-collapsible">
                <summary class="settings-collapsible-header">
                    Speed Test URLs
                    <svg class="chev" width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="settings-collapsible-body">
                    <div class="form-group">
                        <label for="cfg-downloadUrls">Download URLs (one per line)</label>
                        <textarea id="cfg-downloadUrls" rows="3" placeholder="https://..."></textarea>
                    </div>
                    <div class="form-group">
                        <label for="cfg-uploadUrls">Upload URLs (one per line)</label>
                        <textarea id="cfg-uploadUrls" rows="3" placeholder="https://..."></textarea>
                    </div>
                </div>
            </details>

            <details class="settings-collapsible">
                <summary class="settings-collapsible-header">
                    Route Test
                    <svg class="chev" width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="settings-collapsible-body">
                    <div class="form-group">
                        <label for="cfg-route-target">Target</label>
                        <input type="text" id="cfg-route-target" placeholder="8.8.8.8">
                    </div>
                    <div class="form-group">
                        <label for="cfg-route-maxHops">Max Hops</label>
                        <input type="number" id="cfg-route-maxHops" min="1" max="255" placeholder="30">
                    </div>
                    <div class="form-group">
                        <label for="cfg-route-timeoutSeconds">Timeout (s)</label>
                        <input type="number" id="cfg-route-timeoutSeconds" min="1" placeholder="5">
                    </div>
                </div>
            </details>

            <details class="settings-collapsible">
                <summary class="settings-collapsible-header">
                    Jitter Test
                    <svg class="chev" width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="settings-collapsible-body">
                    <div class="form-group">
                        <label for="cfg-jitter-target">Target</label>
                        <input type="text" id="cfg-jitter-target" placeholder="8.8.8.8">
                    </div>
                    <div class="form-group">
                        <label for="cfg-jitter-packetCount">Packet Count</label>
                        <input type="number" id="cfg-jitter-packetCount" min="1" placeholder="10">
                    </div>
                    <div class="form-group">
                        <label for="cfg-jitter-timeoutSeconds">Timeout (s)</label>
                        <input type="number" id="cfg-jitter-timeoutSeconds" min="1" placeholder="5">
                    </div>
                </div>
            </details>

            <details class="settings-collapsible">
                <summary class="settings-collapsible-header">
                    Bandwidth
                    <svg class="chev" width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                </summary>
                <div class="settings-collapsible-body">
                    <div class="form-group">
                        <label for="cfg-bw-initialConnections">Initial Connections</label>
                        <input type="number" id="cfg-bw-initialConnections" min="1" placeholder="1">
                    </div>
                    <div class="form-group">
                        <label for="cfg-bw-maxConnections">Max Connections</label>
                        <input type="number" id="cfg-bw-maxConnections" min="1" placeholder="32">
                    </div>
                    <div class="form-group">
                        <label for="cfg-bw-rampUpStep">Ramp-Up Step</label>
                        <input type="number" id="cfg-bw-rampUpStep" min="1" placeholder="2">
                    </div>
                    <div class="form-group">
                        <label for="cfg-bw-failThreshold">Fail Threshold (%)</label>
                        <input type="number" id="cfg-bw-failThreshold" min="0" max="100" step="1" placeholder="80">
                    </div>
                    <div class="form-group">
                        <label for="cfg-bw-downloadUrl">Download URL</label>
                        <input type="text" id="cfg-bw-downloadUrl" placeholder="https://...">
                    </div>
                </div>
            </details>
        </div>

        <div id="settings-save-error" class="settings-error" style="display:none"></div>

        <div class="form-actions">
            <button type="button" class="cancel-btn" onclick="closeSettingsModal()">Cancel</button>
            <button type="button" class="submit-btn" onclick="saveSettingsConfig()">Save</button>
        </div>
    </div>
</div>
{{end}}

{{define "test_selection"}}
    <select hx-get="/dashboard/tests?date={{.SelectedDate}}&refresh_dropdown=false"
            hx-trigger="change"
            hx-target="#test-results"
            hx-include="this"
            name="type"
            class="">
        {{range .TestTypes}}
            <option value="{{.}}" {{if eq . $.SelectedType}}selected{{end}}>{{.}}</option>
        {{end}}
    </select>
{{end}}

{{define "test_results"}}
    {{if .TestGroups}}
        <div class="test-groups-accordion">
            {{$groupCount := len .TestGroups}}
            <button class="carousel-nav prev"
                    onclick="moveCarousel(-1)"
                    {{if le $groupCount 1}}disabled{{end}}>←</button>
            <button class="carousel-nav next"
                    onclick="moveCarousel(1)"
                    {{if le $groupCount 1}}disabled{{end}}>→</button>
            <div class="carousel-container">
                {{range $index, $group := .TestGroups}}
                    <div class="accordion-item">
                        <div class="accordion-header">
                            Test Group: {{$group.TimeGroup}}
                        </div>
                        <div class="accordion-content">
                            <div class="chart-section">
                                {{range $type, $path := $group.ChartPaths}}
                                    <iframe src="{{$path}}" width="100%" frameborder="0"></iframe>
                                {{end}}
                            </div>
                            <details class="data-section" open>
                                <summary class="data-summary">
                                    <span>Raw data</span>
                                    <svg class="chev" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
                                </summary>
                                <pre>{{printf "%+v" $group.TestResult}}</pre>
                            </details>
                        </div>
                    </div>
                {{end}}
            </div>
        </div>
    {{else}}
        <div class="test-group">
            <div class="chart-section">
                <p>Select a date and test type to view results</p>
            </div>
            <div class="data-section">
                <p>No data available</p>
            </div>
        </div>
    {{end}}
{{end}}